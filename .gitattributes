# Auto detect text files and ensure LF line endings in the repository.
* text=auto eol=lf

# Go source files — always LF.
*.go text eol=lf

# Config files — always LF.
*.yml text eol=lf
*.yaml text eol=lf
*.mod text eol=lf
*.sum text eol=lf

# Shell scripts — always LF.
*.sh text eol=lf

# Markdown — always LF.
*.md text eol=lf

# Windows-specific files — always CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
